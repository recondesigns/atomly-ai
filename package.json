{
  "name": "molecule-ui",
  "version": "0.0.1",
  "private": true,
  "description": "React and Vue component library for the molecule-ui design system.",
  "main": "index.js",
  "scripts": {
    "build:types": "pnpm -F @molecule-ui/types build",
    "build:types-all": "pnpm -F @molecule-ui/types build && pnpm -F @molecule-ui/react build && pnpm -F @molecule-ui/vue build",
    "dev:website": "pnpm -F @molecule-ui/website dev",
    "storybook:react": "pnpm -F @molecule-ui/react storybook",
    "storybook:vue": "pnpm -F @molecule-ui/vue storybook"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "prettier": "^3.8.1",
    "eslint": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@10.14.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/recondesigns/molecule-ui.git"
  },
  "license": "MIT"
}
