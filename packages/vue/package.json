{
  "name": "@molecule-ui/vue",
  "version": "0.0.1",
  "type": "module",
  "description": "Molecule UI Vue components",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./atoms": {
      "types": "./dist/atoms/index.d.ts",
      "import": "./dist/atoms/index.js"
    },
    "./molecules": {
      "types": "./dist/molecules/index.d.ts",
      "import": "./dist/molecules/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && tsc --project tsconfig.build.json --emitDeclarationOnly",
    "dev": "vite build --watch",
    "storybook": "storybook dev -p 6007",
    "build-storybook": "storybook build"
  },
  "peerDependencies": {
    "vue": "^3.4.0"
  },
  "dependencies": {
    "@molecule-ui/types": "workspace:*"
  },
  "devDependencies": {
    "vue": "^3.5.0",
    "vite": "^7.3.1",
    "@vitejs/plugin-vue": "^6.0.4",
    "vue-tsc": "^3.2.4",
    "storybook": "^10.2.10",
    "@storybook/vue3-vite": "^10.2.10",
    "@chromatic-com/storybook": "^5.0.1",
    "@storybook/addon-vitest": "^10.2.10",
    "@storybook/addon-a11y": "^10.2.10",
    "@storybook/addon-docs": "^10.2.10",
    "eslint-plugin-storybook": "^10.2.10",
    "vitest": "^4.0.18",
    "playwright": "^1.58.2",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18"
  },
  "keywords": [
    "design-system",
    "component-library",
    "react",
    "vue"
  ],
  "contributors": [
    {
      "name": "Stedman",
      "url": "https://github.com/recondesigns"
    }
  ],
  "author": {
    "name": "Stedman",
    "url": "https://github.com/recondesigns"
  },
  "homepage": "https://github.com/recondesigns/molecule-ui#readme",
  "bugs": {
    "url": "https://github.com/recondesigns/molecule-ui/issues"
  },
  "license": "MIT",
  "packageManager": "pnpm@10.14.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/recondesigns/molecule-ui.git"
  },
  "eslintConfig": {
    "extends": [
      "plugin:storybook/recommended"
    ]
  }
}
